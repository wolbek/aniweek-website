# Local .terraform directory (contains providers and modules)
.terraform/

# .tfstate files (contain sensitive infrastructure data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files by default (contain secrets/local values)
*.tfvars
*.tfvars.json

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# .terraform.lock.hcl is usually COMMITTED (see below)
# .terraform.lock.hcl
